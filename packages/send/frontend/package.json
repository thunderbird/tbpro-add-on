{
  "name": "send-frontend",
  "version": "7.7.5",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production ./scripts/build.sh",
    "build:dev": "./scripts/build.sh",
    "build:dev:watch": "nodemon -e vue,ts,js,json --ignore 'dist*/' --ignore manifest.json --watch './{src,public}/**/*' --exec 'pnpm build:dev'",
    "build:watch": "nodemon -e vue,ts,js,json --watch './{src,public}/**/*' --exec 'pnpm build'",
    "ci:validate": "pnpm lint:all; pnpm prettier:all; pnpm run test; pnpm run typecheck",
    "dev": "vite --host",
    "lint:all": "pnpx eslint src/**/*.ts --fix",
    "prettier:all": "prettier --write .",
    "preview": "vite preview",
    "release": "./scripts/release.sh",
    "sort-package-json": "sort-package-json",
    "test": "VITE_TESTING=true vitest run --silent",
    "test:watch": "VITE_TESTING=true vitest --watch",
    "test-debug": "VITE_TESTING=true vitest --inspect-brk --single-thread",
    "typecheck": "tsc --noEmit",
    "postversion": "bun run ./scripts/bump.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@scure/bip39": "^1.6.0",
    "@sentry/vite-plugin": "^5.2.1",
    "@sentry/vue": "^8.55.2",
    "@tabler/icons-vue": "^2.47.0",
    "@tanstack/vue-query": "^5.100.6",
    "@thunderbirdops/services-ui": "^1.6.2",
    "@trpc/client": "^11.17.0",
    "@types/ua-parser-js": "^0.7.39",
    "dayjs": "^1.11.20",
    "floating-vue": "^5.2.2",
    "get-random-values": "^3.0.0",
    "install": "^0.13.0",
    "jszip": "^3.10.1",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^2.3.1",
    "posthog-js": "^1.372.5",
    "pretty-bytes": "^6.1.1",
    "ua-parser-js": "^1.0.41",
    "vue": "^3.5.33",
    "vue-final-modal": "^4.5.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@trpc/server": "^11.17.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/firefox-webext-browser": "^120.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/thunderbird-webext-browser": "^127.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.9",
    "@vueuse/core": "^10.11.1",
    "autoprefixer": "^10.5.0",
    "buffer": "^6.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "form-data": "^4.0.5",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "jsonwebtoken": "9.0.2",
    "lint-staged": "^15.5.2",
    "mock-socket": "^9.3.1",
    "msw": "^2.14.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.12",
    "postcss-import": "^15.1.0",
    "prettier": "^3.8.3",
    "sort-package-json": "^3.6.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "typescript-language-server": "^3.3.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vitest-localstorage-mock": "^0.0.1",
    "vitest-websocket-mock": "^0.4.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
